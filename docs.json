{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Outfox AI Docs",
  "colors": {
    "primary": "#F59E0B",
    "light": "#FBBF24",
    "dark": "#E8723A"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "development"]
          },
          {
            "group": "MCP platform",
            "pages": [
              "platform/overview",
              "platform/authentication",
              "platform/example-workflows"
            ]
          },
          {
            "group": "Tool families",
            "pages": [
              "platform/inspiration-tools",
              "platform/meta-analytics-tools",
              "platform/prompt-recipes",
              "platform/deployment-vercel"
            ]
          },
          {
            "group": "AI tools",
            "pages": ["ai-tools/cursor", "ai-tools/claude-code"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Reference overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Tool catalogs",
            "pages": [
              "api-reference/brand-and-analysis",
              "api-reference/inspiration",
              "api-reference/meta-analytics"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Open app",
          "href": "https://app.outfox.ai",
          "icon": "rocket"
        },
        {
          "anchor": "MCP guide",
          "href": "https://app.outfox.ai/mcp-guide",
          "icon": "book-open-cover"
        },
        {
          "anchor": "MCP endpoint",
          "href": "https://app.outfox.ai/api/mcp",
          "icon": "plug"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/outfoxai/app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Outfox",
      "href": "https://app.outfox.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/outfoxai"
    }
  }
}
